      "**/*.key": "deny",
      "**/credentials*.json": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "*.env.example": "allow",
      "*.env.sample": "allow",
      "*.env.template": "allow",
      "~/Music/**": "deny",
      "~/Documents/**": "deny",
      "~/Pictures/**": "deny",
      "~/Videos/**": "deny",
      "~/Downloads/**": "deny",
      "~/Desktop/**": "deny",
      "~/.aws/**": "deny",
      "~/.claude.json": "deny",
      "~/.claude/**": "deny",
      "~/.codex/**": "deny",
      "~/.doppler/**": "deny",
      "~/.gemini/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.netrc": "deny",
      "~/.opencode/**": "deny",
      "~/.ssh/**": "deny",
      "~/.talos/**": "deny",
      "~/.vorpal/**": "deny"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/secrets/**": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/credentials*.json": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "~/Music/**": "deny",
      "~/Documents/**": "deny",
      "~/Pictures/**": "deny",
      "~/Videos/**": "deny",
