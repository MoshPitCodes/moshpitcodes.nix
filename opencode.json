{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "team-lead",
  "plugin": [
    ".opencode/plugins/security.ts",
    ".opencode/plugins/logging.ts",
    ".opencode/plugins/notifications.ts",
    ".opencode/plugins/post-stop-detector.ts",
    ".opencode/plugins/td-enforcer.ts",
    ".opencode/plugins/icm.ts"
  ],
  "permission": {
    "*": "ask",
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
